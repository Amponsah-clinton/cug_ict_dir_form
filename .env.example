# Required in production
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.railway.app,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.railway.app,https://yourdomain.com

# Optional — only needed if using a separate Postgres DB for Django sessions
# Leave blank to use SQLite (fine for single-instance deploys)
DATABASE_URL=
